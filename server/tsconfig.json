{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "@server/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../scripts/**/*.ts"]
}
